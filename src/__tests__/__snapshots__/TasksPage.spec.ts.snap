// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TasksPage > renders stable markup 1`] = `
"<q-page-stub class="page page-enter">
  <header class="page-head">
    <div class="page-eyebrow">pages.tasks.eyebrow</div>
    <h1 class="page-title">pages.tasks.title</h1>
    <p class="page-sub">pages.tasks.subtitle</p>
  </header>
  <div class="tasks-list">
    <div class="tasks-row"><button type="button" class="tasks-row-main" aria-label="pages.tasks.editTask: Sports"><span class="freq" aria-hidden="true">3 <span class="x">pages.tasks.freqSuffix</span></span><span class="body"><span class="title">Sports</span><span class="hint">pages.tasks.hintDaysOfSeven</span></span></button><button class="icon-btn" type="button" aria-label="pages.tasks.deleteTask">
        <q-icon-stub name="delete_outline"></q-icon-stub>
      </button></div>
  </div><button type="button" class="add-cta"> + pages.tasks.newTask</button>
  <div></div>
  <div persistent="">
    <div class="sheet-card" style="max-width: 420px;">
      <div class="grab" aria-hidden="true"></div>
      <h2>pages.tasks.deleteTask</h2>
      <p class="sub">pages.tasks.deleteConfirm</p>
      <div class="sheet-actions"><button type="button" class="ghost-btn">common.cancel</button><button type="button" class="primary-btn">common.delete</button></div>
    </div>
  </div>
</q-page-stub>"
`;
