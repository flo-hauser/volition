// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SettingsPage > renders stable markup 1`] = `
"<div data-v-4ff3282c="" class="page page-enter">
  <header data-v-4ff3282c="" class="page-head"><button data-v-4ff3282c="" class="icon-btn" type="button" style="margin-bottom: 12px;" aria-label="common.back"><span data-v-4ff3282c="" name="arrow_back"></span></button>
    <div data-v-4ff3282c="" class="page-eyebrow">nav.settings</div>
    <h1 data-v-4ff3282c="" class="page-title">pages.settings.title</h1>
    <p data-v-4ff3282c="" class="page-sub">pages.settings.hint</p>
  </header>
  <section data-v-4ff3282c="" class="settings-section">
    <h2 data-v-4ff3282c="" class="section-title">pages.settings.languageTitle</h2>
    <div data-v-4ff3282c="" class="seg"><button data-v-4ff3282c="" type="button" class="seg-btn sel" aria-pressed="true">pages.settings.localeEnglish</button><button data-v-4ff3282c="" type="button" class="seg-btn" aria-pressed="false">pages.settings.localeGerman</button></div>
  </section>
  <section data-v-4ff3282c="" class="settings-section">
    <h2 data-v-4ff3282c="" class="section-title">pages.settings.themeTitle</h2>
    <div data-v-4ff3282c="" class="seg"><button data-v-4ff3282c="" type="button" class="seg-btn sel" aria-pressed="true">pages.settings.themeSystem</button><button data-v-4ff3282c="" type="button" class="seg-btn" aria-pressed="false">pages.settings.themeLight</button><button data-v-4ff3282c="" type="button" class="seg-btn" aria-pressed="false">pages.settings.themeDark</button></div>
    <p data-v-4ff3282c="" class="settings-hint">pages.settings.themeHint</p>
  </section>
  <section data-v-4ff3282c="" class="settings-section">
    <h2 data-v-4ff3282c="" class="section-title">pages.settings.weekStart.label</h2>
    <div data-v-4ff3282c="" class="seg"><button data-v-4ff3282c="" type="button" class="seg-btn sel" aria-pressed="true">pages.settings.weekStart.monday</button><button data-v-4ff3282c="" type="button" class="seg-btn" aria-pressed="false">pages.settings.weekStart.sunday</button></div>
  </section>
  <section data-v-4ff3282c="" class="settings-section">
    <h2 data-v-4ff3282c="" class="section-title">legal.sectionTitle</h2>
    <div data-v-4ff3282c="" class="legal-links"><button data-v-4ff3282c="" type="button" class="legal-link">legal.imprintLink</button><button data-v-4ff3282c="" type="button" class="legal-link">legal.privacyLink</button></div>
  </section>
  <section data-v-4ff3282c="" class="settings-section">
    <h2 data-v-4ff3282c="" class="section-title">pages.settings.backup.title</h2>
    <div data-v-4ff3282c="" class="settings-row">
      <div data-v-4ff3282c="" class="settings-row__body"><span data-v-4ff3282c="" class="settings-row__label">pages.settings.backup.exportLabel</span><span data-v-4ff3282c="" class="settings-row__hint">pages.settings.backup.exportHint</span></div><button data-v-4ff3282c="" type="button" class="ghost-btn">pages.settings.backup.exportBtn</button>
    </div>
    <div data-v-4ff3282c="" class="settings-row">
      <div data-v-4ff3282c="" class="settings-row__body"><span data-v-4ff3282c="" class="settings-row__label">pages.settings.backup.importLabel</span><span data-v-4ff3282c="" class="settings-row__hint">pages.settings.backup.importHint</span></div><label data-v-4ff3282c="" class="ghost-btn">pages.settings.backup.importBtn <input data-v-4ff3282c="" type="file" accept=".json,application/json" hidden=""></label>
    </div>
  </section>
  <q-dialog data-v-4ff3282c="" modelvalue="false">
    <div data-v-4ff3282c="" class="sheet-card" style="max-width: 420px;">
      <div data-v-4ff3282c="" class="grab" aria-hidden="true"></div>
      <h2 data-v-4ff3282c="">pages.settings.backup.importConfirmTitle</h2>
      <p data-v-4ff3282c="" class="sub">pages.settings.backup.importConfirm</p>
      <!--v-if-->
      <div data-v-4ff3282c="" class="sheet-actions"><button data-v-4ff3282c="" type="button" class="ghost-btn">common.cancel</button><button data-v-4ff3282c="" type="button" class="primary-btn">common.confirm</button></div>
    </div>
  </q-dialog>
  <section data-v-4ff3282c="" class="settings-section debug-toggle-section"><button data-v-4ff3282c="" type="button" class="debug-toggle-btn"> Debug ▾</button></section>
  <!--v-if-->
</div>"
`;
